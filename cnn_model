# ==========================================
# 2. UTILS & TRANSFORMATIONS
# ==========================================
# We must standardize all images before the CNN sees them.
# 1. Resize: CNNs expect a fixed input size (224x224 is standard for image classification/regression).
# 2. ToTensor: Converts the image from a PIL format (pixels 0-255) into a PyTorch tensor (floats 0.0-1.0).
transform = T.Compose([
    T.Resize((224, 224)),
    T.ToTensor(),
])

# Modified collate_fn to include numerical features
def collate_fn(batch):
    imgs = [x["image"] for x in batch]
    numerical_data = [x["numerical_data"] for x in batch]
    labels = [x["pm25"] for x in batch]
    return torch.stack(imgs), torch.stack(numerical_data), torch.tensor(labels, dtype=torch.float32)

# ===== Define Multimodal Model =====
class MultimodalModel(nn.Module):
    def __init__(self, num_numerical_features=5):
        super().__init__()

        # Exclusively use VGG16 as the backbone
        vgg = models.vgg16(weights='DEFAULT')
        self.image_feature_extractor = nn.Sequential(
            vgg.features,
            nn.AdaptiveAvgPool2d((1,1)) # VGG features output different sizes, use adaptive pool to get fixed size
        )
        image_feature_output_size = 512 # VGG16 with AdaptiveAvgPool2d((1,1)) outputs 512 features

        # Define a simple MLP for numerical features
        self.numerical_processor = nn.Sequential(
            nn.Linear(num_numerical_features, 64),
            nn.ReLU(),
            nn.Linear(64, 64),
            nn.ReLU()
        )

        # The output feature size from the image model and the numerical processor
        combined_features_size = image_feature_output_size + 64

        # Final regression head
        self.regressor = nn.Linear(combined_features_size, 1)

    def forward(self, img_input, num_input):
        # Process image data
        img_features = self.image_feature_extractor(img_input)
        # Flatten the features from the image model (it's 1x1xC after avg pool)
        img_features = img_features.view(img_features.size(0), -1)

        # Process numerical data
        num_features = self.numerical_processor(num_input)

        # Concatenate features from both modalities
        combined_features = torch.cat((img_features, num_features), dim=1)

        # Pass through regression head
        return self.regressor(combined_features).squeeze(1)


# ===== Dataset Class =====
from torch.utils.data import Dataset, random_split

class RealDataDataset(Dataset):
    def __init__(self, dataframe, image_size=(224, 224), numerical_cols=None, transform=None):
        # Make a deep copy to ensure modifications don't affect original df outside
        self.dataframe = dataframe.copy()
        self.image_size = image_size
        self.transform = transform if transform else T.Compose([T.Resize(image_size), T.ToTensor()])

        if numerical_cols is None:
            # Default numerical columns from era5_df info and project outline
            self.numerical_cols = [
                'temp_celsius', 'dewpoint_celsius', 'rh_pct',
                'wind_speed_m_s', 'pressure_hpa'
            ]
        else:
            self.numerical_cols = numerical_cols

        # Ensure all numerical columns exist in the dataframe and are numeric
        for col in self.numerical_cols:
            if col not in self.dataframe.columns:
                raise ValueError(f"Numerical column '{col}' not found in the DataFrame.")
            # Convert to numeric, coercing errors to NaN
            self.dataframe[col] = pd.to_numeric(self.dataframe[col], errors='coerce')

        # Drop rows with NaN in numerical columns after conversion
        self.dataframe.dropna(subset=self.numerical_cols, inplace=True)

        # Explicitly convert numerical columns to float32 after cleaning to ensure consistent type
        for col in self.numerical_cols:
            self.dataframe[col] = self.dataframe[col].astype(np.float32)

        # Ensure 'pm25' column is numeric and handle NaNs for the label
        if 'pm25' in self.dataframe.columns:
            self.dataframe['pm25'] = pd.to_numeric(self.dataframe['pm25'], errors='coerce')
            self.dataframe.dropna(subset=['pm25'], inplace=True) # Drop rows where pm25 label is NaN
            self.dataframe['pm25'] = self.dataframe['pm25'].astype(np.float32) # Cast label to float32
        else:
            raise ValueError("pm25 column not found in DataFrame. This is required for PM2.5 labels.")

    def __len__(self):
        return len(self.dataframe)

    def __getitem__(self, idx):
        row = self.dataframe.iloc[idx]

        img_bytes = row['image']
        img = Image.open(BytesIO(img_bytes)).convert("RGB")
        
        # Resize first, then manually convert to tensor (bypasses broken ToTensor)
        img = img.resize((224, 224))
        img_tensor = torch.from_numpy(np.array(img, dtype=np.float32) / 255.0).permute(2, 0, 1)

        numerical_features = torch.tensor(row[self.numerical_cols].to_numpy(dtype=np.float32), dtype=torch.float32)
        label = row['pm25']

        return {"image": img_tensor, "pm25": label, "numerical_data": numerical_features}


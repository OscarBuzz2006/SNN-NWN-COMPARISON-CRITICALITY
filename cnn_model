print(f"\nTotal rows after merge: {len(merged_df)}")
print(f"Rows with matching CSV data: {merged_df['temp_celsius'].notna().sum()}")  # Replace with any era5 column name

# Define the numerical features to be used in the model
numerical_feature_columns = [
    'temp_celsius', 'dewpoint_celsius', 'rh_pct',
    'wind_speed_m_s', 'pressure_hpa'
]



# IMPORTANT  NOTE - SEE MERGE UPDATE NOTE

# Create the full dataset using the merged dataframe
print("\nCreating dataset...")
# Split the dataframe first, then create separate datasets
merged_df_clean = merged_df.dropna(subset=numerical_feature_columns + ['pm25']).reset_index(drop=True)

train_size = int(0.8 * len(merged_df_clean))
train_df = merged_df_clean.iloc[:train_size].reset_index(drop=True)
test_df  = merged_df_clean.iloc[train_size:].reset_index(drop=True)

train_dataset = RealDataDataset(dataframe=train_df, numerical_cols=numerical_feature_columns, transform=transform)
test_dataset  = RealDataDataset(dataframe=test_df,  numerical_cols=numerical_feature_columns, transform=transform)

ds = {
    "train": train_dataset,
    "test": test_dataset
}

# Setup device
device = "cuda" if torch.cuda.is_available() else "cpu"

# Create DataLoaders
train_loader = DataLoader(ds["train"], batch_size=32, shuffle=True, collate_fn=collate_fn)
test_loader = DataLoader(ds["test"], batch_size=32, shuffle=False, collate_fn=collate_fn)

# Instantiate the multimodal model with VGG16 backbone
print("\nInitializing model...")
model = MultimodalModel(num_numerical_features=len(numerical_feature_columns)).to(device)

# Using a slightly lower learning rate is better for pre-trained models
optimizer = optim.Adam(model.parameters(), lr=1e-4)
criterion = nn.MSELoss()

print(f"Using device: {device}")

# ==========================================
# 4. MAIN EXECUTION & TRAINING LOOP
# ==========================================
epochs = 5

# 2. THE LOOP
for epoch in range(epochs):

    # -------------------------
    # --- TRAINING PHASE ---
    # -------------------------
    model.train()
    train_loss = 0.0

    for imgs, numerical_data, labels in tqdm(train_loader, desc=f"Epoch {epoch+1}/{epochs} [Train]"):
        imgs, numerical_data, labels = imgs.to(device), numerical_data.to(device), labels.to(device)

        optimizer.zero_grad()

        outputs = model(imgs, numerical_data)

        loss = criterion(outputs, labels)

        loss.backward()

        optimizer.step()

        train_loss += loss.item()

    avg_train_loss = train_loss / len(train_loader)

    # -------------------------
    # --- TESTING PHASE ---
    # -------------------------
    model.eval()
    test_loss = 0.0

    with torch.no_grad():
        for imgs, numerical_data, labels in tqdm(test_loader, desc=f"Epoch {epoch+1}/{epochs} [Test]"):
            imgs, numerical_data, labels = imgs.to(device), numerical_data.to(device), labels.to(device)

            outputs = model(imgs, numerical_data)
            loss = criterion(outputs, labels)

            test_loss += loss.item()

    avg_test_loss = test_loss / len(test_loader)

    # -------------------------
    # --- RESULTS ---
    # -------------------------
    print(f"Epoch {epoch+1} Complete | Train Loss: {avg_train_loss:.4f} | Test Loss: {avg_test_loss:.4f}\n")

# Save the trained model
torch.save(model.state_dict(), 'trained_model.pth')
print("Model saved to 'trained_model.pth'")

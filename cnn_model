# 1. Load DataFrames
print("Loading CSV file...")
era5_df = pd.read_csv('/Users/Not_remy/ENGG2212_ML/FINAL_era5_pm25_weather_data_WITH_FILENAMES.csv')

print("Loading Hugging Face dataset...")
